# Unsplash API Configuration
# Get your access key from https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_access_key_here

# Base URL for Open Graph metadata and absolute URLs
# Production: https://yourdomain.com
# Development: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Note: Apply for production API access immediately
# Demo tier: 50 requests/hour (insufficient for real traffic)
# Production tier: 5000 requests/hour
# Apply at: Your Unsplash App Settings → Request Production Access
